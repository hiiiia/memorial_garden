# Raspberry Pi 5 local whisper.cpp STT
# base.en is English-only. Use multilingual ggml-base.bin for Korean.
WHISPER_CPP_BIN=/home/pi/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=/home/pi/whisper.cpp/models/ggml-base.bin
WHISPER_LANGUAGE=ko
WHISPER_THREADS=3
WHISPER_NICE=10
WHISPER_TIMEOUT_SECONDS=180

# Existing agent/backend/AI values are usually supplied by hardware/.env.
# Do not commit real tokens or device identifiers.
