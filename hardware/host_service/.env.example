# 기본값은 Google voiceHAT Soundcard를 /proc/asound/cards 및 ALSA 목록에서 자동 탐색합니다.
AUDIO_CARD_MATCH=Google voiceHAT Soundcard

# 자동 탐색이 실패할 때만 ALSA 장치명을 직접 지정하세요. 비워두면 자동 탐색합니다.
AUDIO_CAPTURE_DEVICE=
AUDIO_PLAYBACK_DEVICE=

# 상대 경로는 hardware/host_service 기준입니다.
AUDIO_RECORDINGS_DIR=recordings

HARDWARE_PORT=8002
HARDWARE_LOG_LEVEL=INFO

# hardware.agent 실행 시 사용합니다. 실제 I2S 제어는 host 모드에서만 활성화됩니다.
# Docker agent는 기본값 docker 안전 모드로 동작하며 arecord/aplay를 호출하지 않습니다.
HARDWARE_RUNTIME_MODE=host

# 쉼표로 구분합니다. 원격 개발 PC의 origin은 필요할 때 명시적으로 추가하세요.
HARDWARE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173
